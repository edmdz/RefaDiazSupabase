    {
      "name": "02 Brands Flow",
      "item": [
        {
          "name": "POST /brands",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = Date.now().toString();",
                  "pm.collectionVariables.set('brandNameCreate', `Postman Brand ${suffix}`);",
                  "pm.collectionVariables.set('brandSlugCreate', `postman-brand-${suffix}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('brandIdCreated', String(body.id));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{brandNameCreate}}\",\n  \"brandTypeId\": 1,\n  \"active\": true,\n  \"file\": {\n    \"name\": \"{{brandNameCreate}} Logo\",\n    \"mimeType\": \"image/png\",\n    \"storagePath\": \"/brands/logos/{{brandSlugCreate}}.png\"\n  }\n}"
            },
            "url": "{{baseUrl}}/brands"
          }
        },
        {
          "name": "GET /brands?id={{brandIdCreated}}",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/brands?id={{brandIdCreated}}"
          }
        },
        {
          "name": "PUT /brands?id={{brandIdCreated}}",
