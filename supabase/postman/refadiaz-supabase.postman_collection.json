    {
      "name": "07 Products Flow",
      "item": [
        {
          "name": "Components Example Flow",
          "item": [
            {
              "name": "POST /products component (TAPA)",
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const suffix = Date.now().toString();",
                      "pm.collectionVariables.set('componentProductNameCreate', `POSTMAN COMPONENT ${suffix}`);",
                      "pm.collectionVariables.set('componentProductDpiCreate', `PM-COMP-${suffix}`);",
                      "pm.collectionVariables.set('componentProductFileNameCreate', `postman-component-${suffix}`);"
                    ]
                  }
                },
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const body = pm.response.json();",
                      "pm.collectionVariables.set('componentProductIdCreated', String(body.id));"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"{{componentProductNameCreate}}\",\n  \"comments\": \"Postman component product example\",\n  \"stockCount\": 10,\n  \"dpi\": \"{{componentProductDpiCreate}}\",\n  \"productTypeId\": {{productTypeIdTapa}},\n  \"files\": [\n    {\n      \"name\": \"{{componentProductFileNameCreate}}.png\",\n      \"mimeType\": \"image/png\",\n      \"storagePath\": \"products/images/{{componentProductFileNameCreate}}.png\",\n      \"orderId\": 1\n    }\n  ],\n  \"productProviders\": [\n    {\n      \"providerId\": {{providerIdSeed}},\n      \"numSeries\": \"PM-COMP-SERIES-001\",\n      \"price\": {\n        \"description\": \"Costo tapa Postman\",\n        \"cost\": \"$555.00\"\n      }\n    }\n  ],\n  \"productPrices\": [\n    {\n      \"price\": {\n        \"description\": \"Venta tapa Postman\",\n        \"cost\": \"$999.00\"\n      }\n    }\n  ]\n}"
                },
                "url": "{{baseUrl}}/products"
              }
            },
            {
              "name": "GET /products?id={{componentProductIdCreated}}",
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/products?id={{componentProductIdCreated}}"
              }
            },
            {
              "name": "POST /products radiator with components",
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const suffix = Date.now().toString();",
