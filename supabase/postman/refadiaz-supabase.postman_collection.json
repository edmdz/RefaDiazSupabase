            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{brandNameUpdate}}\",\n  \"brandTypeId\": 1,\n  \"active\": true,\n  \"file\": {\n    \"name\": \"{{brandNameUpdate}} Logo\",\n    \"mimeType\": \"image/png\",\n    \"storagePath\": \"/brands/logos/{{brandSlugUpdate}}.png\"\n  }\n}"
